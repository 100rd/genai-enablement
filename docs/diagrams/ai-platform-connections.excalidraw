  },
  {
   "id": "text-9371",
   "type": "text",
   "x": 125,
   "y": 2654,
   "width": 319.06,
   "height": 192.5,
   "angle": 0,
   "strokeColor": "#1e1e1e",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "strokeWidth": 2,
   "strokeStyle": "solid",
   "roughness": 1,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "roundness": null,
   "seed": 290501,
   "version": 1,
   "versionNonce": 908987,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "RUNTIME (mitigation, seconds):\n  canary metrics breach → Argo Rollouts\n  aborts & reverts automatically\n\nDURABLE (factory, auditable):\n  git revert via the same GitOps path;\n  omnius: saga compensators + IntentClaim;\n  ephemeral env = the sandbox rollback\n\nRollback DECISION is deterministic — an LLM\nmay propose, only metrics/humans trigger.",
   "fontSize": 14,
   "fontFamily": 6,
   "textAlign": "left",
   "verticalAlign": "top",
   "baseline": 14,
   "containerId": null,
   "originalText": "RUNTIME (mitigation, seconds):\n  canary metrics breach → Argo Rollouts\n  aborts & reverts automatically\n\nDURABLE (factory, auditable):\n  git revert via the same GitOps path;\n  omnius: saga compensators + IntentClaim;\n  ephemeral env = the sandbox rollback\n\nRollback DECISION is deterministic — an LLM\nmay propose, only metrics/humans trigger.",
   "lineHeight": 1.25
  },
