  {
   "id": "text-9133",
   "type": "text",
   "x": 2005,
   "y": 85,
   "width": 508.8,
   "height": 131.25,
   "angle": 0,
   "strokeColor": "#1e1e1e",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "strokeWidth": 2,
   "strokeStyle": "solid",
   "roughness": 1,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "roundness": null,
   "seed": 283123,
   "version": 1,
   "versionNonce": 885901,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "① Prevention — change-gate in CI, blocks bad changes pre-deploy\n② Detection — thresholds, canary metrics, Sentinel trend/drift\n③ Knowledge — bitemporal platform graph (timeline, blast_radius)\n④ Reasoning — T1 triage / T2 advisory · the ONLY layer with LLM\n⑤ Safety — tiers T1–T4, action-tier table, verdicts; never LLM\n⑥ Action — T4 auto (reversible) / T3 human-approved / GitOps PR\n⑦ Learning — postmortem → runbook-skill → registry → faster loop",
   "fontSize": 15,
   "fontFamily": 6,
   "textAlign": "left",
   "verticalAlign": "top",
   "baseline": 15,
   "containerId": null,
   "originalText": "① Prevention — change-gate in CI, blocks bad changes pre-deploy\n② Detection — thresholds, canary metrics, Sentinel trend/drift\n③ Knowledge — bitemporal platform graph (timeline, blast_radius)\n④ Reasoning — T1 triage / T2 advisory · the ONLY layer with LLM\n⑤ Safety — tiers T1–T4, action-tier table, verdicts; never LLM\n⑥ Action — T4 auto (reversible) / T3 human-approved / GitOps PR\n⑦ Learning — postmortem → runbook-skill → registry → faster loop",
   "lineHeight": 1.25
  },
