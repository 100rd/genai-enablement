  {
   "id": "text-1248",
   "type": "text",
   "x": 1060,
   "y": 780,
   "width": 704.9000000000001,
   "height": 17.5,
   "angle": 0,
   "strokeColor": "#868e96",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "strokeWidth": 2,
   "strokeStyle": "solid",
   "roughness": 1,
