{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pii-permit.schema.json",
  "title": "PIIPermit",
  "description": "SPEC-PII-POLICY REQ-PII-POL-5 / ADR-0018 D5,D7. Short-lived, single-purpose, exact permit. issuer, subject, fields, source, sink/provider/tool, actor/workload, tenant/workspace, retention, policy revision, issue/expiry and nonce are mandatory. Widening, consumer refresh, or reuse for another sink is a semantic-validator concern (see check_permit_widen / check_permit_replay), not expressible as a structural schema rule alone.",
  "type": "object",
  "required": [
    "permit_id",
    "issuer",
    "tenant_id",
    "purpose_id",
    "actor_or_workload",
    "source_constraints",
    "allowed_fields",
    "allowed_sinks",
    "provider_constraints",
    "transform_requirements",
    "retention_deadline",
    "issued_at",
    "expires_at",
    "policy_revision",
    "nonce",
    "integrity"
  ],
  "additionalProperties": true,
  "properties": {
    "permit_id": { "type": "string", "minLength": 1 },
    "issuer": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "subject_ref": { "type": "string", "minLength": 1 },
    "purpose_id": { "type": "string", "minLength": 1 },
    "actor_or_workload": { "type": "string", "minLength": 1 },
    "source_constraints": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "allowed_fields": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "allowed_sinks": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "provider_constraints": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "transform_requirements": { "type": "array", "items": { "$ref": "transform-state.schema.json" } },
    "retention_deadline": { "type": "string", "minLength": 1 },
    "issued_at": { "type": "string", "minLength": 1 },
    "expires_at": { "type": "string", "minLength": 1 },
    "policy_revision": { "type": "string", "minLength": 1 },
    "nonce": { "type": "string", "minLength": 8 },
    "integrity": { "$ref": "integrity.schema.json" }
  }
}
