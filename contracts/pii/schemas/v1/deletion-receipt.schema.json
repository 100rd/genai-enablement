{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deletion-receipt.schema.json",
  "title": "DeletionReceipt",
  "description": "SPEC-PII-POLICY REQ-PII-POL-6, REQ-PII-POL-7 / ADR-0018 D8. Per-store lifecycle evidence. 'disposition' is the top-level claimed aggregate; 'store_states' is the itemized per-store evidence the aggregate must be consistent with (checked by the semantic validator's aggregate_lifecycle, since a structural schema cannot express that cross-field consistency rule).",
  "type": "object",
  "required": [
    "request_id",
    "tenant_id",
    "policy_revision",
    "store_class",
    "covered_artifacts",
    "excluded_or_pending",
    "disposition",
    "store_states",
    "produced_at",
    "producer",
    "integrity"
  ],
  "additionalProperties": true,
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "subject_ref": { "type": "string", "minLength": 1 },
    "policy_revision": { "type": "string", "minLength": 1 },
    "store_class": { "type": "string", "minLength": 1 },
    "covered_artifacts": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "excluded_or_pending": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "disposition": { "$ref": "disposition.schema.json" },
    "store_states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["store", "disposition"],
        "additionalProperties": true,
        "properties": {
          "store": { "type": "string", "minLength": 1 },
          "disposition": { "$ref": "disposition.schema.json" }
        }
      }
    },
    "produced_at": { "type": "string", "minLength": 1 },
    "producer": { "type": "string", "minLength": 1 },
    "integrity": { "$ref": "integrity.schema.json" }
  }
}
