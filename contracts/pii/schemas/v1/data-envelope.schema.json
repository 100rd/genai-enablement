{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "data-envelope.schema.json",
  "title": "DataEnvelope",
  "description": "SPEC-PII-POLICY REQ-PII-POL-4 / ADR-0018 D5. Binds tenant/workspace, subject/source, purpose, data class, transformation, allowed fields and sinks, policy revision, lineage, issue/expiry, coverage and integrity. The value and policy metadata must not be separated during propagation; that invariant is enforced by the semantic validator's widen-only checks, not by this structural schema alone.",
  "type": "object",
  "required": [
    "envelope_id",
    "tenant_id",
    "source_ref",
    "data_class",
    "transform_state",
    "field_manifest",
    "allowed_fields",
    "allowed_sinks",
    "policy_revision",
    "produced_at",
    "integrity"
  ],
  "additionalProperties": true,
  "properties": {
    "envelope_id": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "source_ref": { "type": "string", "minLength": 1 },
    "subject_ref": { "type": "string", "minLength": 1 },
    "purpose_id": { "type": "string", "minLength": 1 },
    "permit_id": { "type": "string", "minLength": 1 },
    "data_class": { "$ref": "data-class.schema.json" },
    "transform_state": { "$ref": "transform-state.schema.json" },
    "field_manifest": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "allowed_fields": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "allowed_sinks": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "policy_revision": { "type": "string", "minLength": 1 },
    "lineage": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "produced_at": { "type": "string", "minLength": 1 },
    "expires_at": { "type": "string", "minLength": 1 },
    "coverage": { "type": "string", "minLength": 1 },
    "integrity": { "$ref": "integrity.schema.json" }
  }
}
