# AI Incident Intelligence Agent - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# AWS Configuration
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
AWS_PROFILE=default  # Optional: for local development

# ============================================================================
# LLM Configuration
# ============================================================================

# Primary LLM Provider (choose one: bedrock, sagemaker, openai)
LLM_PROVIDER=bedrock

# Option 1: AWS Bedrock (Recommended)
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_REGION=us-east-1
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.1

# Option 2: AWS SageMaker (Self-hosted)
# SAGEMAKER_ENDPOINT_NAME=llama-3-70b-instruct-endpoint
# SAGEMAKER_REGION=us-east-1

# Option 3: OpenAI (External - requires data review!)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4-turbo
# OPENAI_MAX_TOKENS=4096
# OPENAI_TEMPERATURE=0.1

# Low-priority alerts LLM (faster, cheaper)
LLM_FAST_PROVIDER=bedrock
LLM_FAST_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# ============================================================================
# AWS Data Storage
# ============================================================================

# DynamoDB Tables
DYNAMODB_INCIDENT_STATE_TABLE=incident_state
DYNAMODB_INCIDENT_HISTORY_TABLE=incident_history
DYNAMODB_AGENT_MEMORY_TABLE=agent_memory
DYNAMODB_RUNBOOK_INDEX_TABLE=runbook_index

# S3 Buckets
S3_ARTIFACTS_BUCKET=ai-incident-agent-artifacts
S3_RUNBOOK_BUCKET=ai-incident-agent-runbooks
S3_REGION=us-east-1

# OpenSearch
OPENSEARCH_ENDPOINT=https://search-ai-incident-agent.us-east-1.es.amazonaws.com
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=  # Leave empty if using IAM auth
OPENSEARCH_USE_IAM=true
OPENSEARCH_REGION=us-east-1

# ============================================================================
# Event Processing
# ============================================================================

# SQS Queue
SQS_ALERT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/ai-agent-alert-queue
SQS_DLQ_URL=https://sqs.us-east-1.amazonaws.com/123456789012/ai-agent-alert-dlq
SQS_VISIBILITY_TIMEOUT=300  # seconds
SQS_MAX_MESSAGES=10
SQS_WAIT_TIME=20  # Long polling

# ============================================================================
# Notification Channels
# ============================================================================

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_CHANNEL_INCIDENTS=#incidents
SLACK_CHANNEL_CRITICAL=#critical-alerts
SLACK_ENABLE_THREADS=true
SLACK_ENABLE_REACTIONS=true

# PagerDuty (Optional)
PAGERDUTY_API_KEY=  # Leave empty to disable
PAGERDUTY_ROUTING_KEY=  # Integration key for service
PAGERDUTY_FROM_EMAIL=ai-agent@company.com

# Microsoft Teams (Optional)
MS_TEAMS_WEBHOOK_URL=  # Leave empty to disable

# ============================================================================
# Agent Configuration
# ============================================================================

# Processing
ALERT_PROCESSING_TIMEOUT=300  # seconds (5 minutes)
MAX_CONCURRENT_INCIDENTS=10
ENABLE_ALERT_DEDUPLICATION=true
DEDUPLICATION_WINDOW_SECONDS=300

# Context Gathering
MAX_CONTEXT_LOGS=100
LOGS_LOOKBACK_SECONDS=300  # 5 minutes before alert
LOGS_LOOKFORWARD_SECONDS=60  # 1 minute after alert
MAX_METRICS_DATAPOINTS=100
ENABLE_XRAY_TRACES=true
ENABLE_SIMILAR_INCIDENT_SEARCH=true

# Analysis
SIMILARITY_THRESHOLD=0.75  # For matching past incidents (0.0 - 1.0)
MIN_RUNBOOK_MATCH_SCORE=0.70
MAX_RUNBOOKS_TO_RETURN=3
ENABLE_ROOT_CAUSE_ANALYSIS=true
ENABLE_IMPACT_ASSESSMENT=true

# Runbook Matching
RUNBOOK_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RUNBOOK_SEARCH_TOP_K=5

# Safety & Guardrails
ENABLE_AUTO_REMEDIATION=false  # CAUTION: Only enable after extensive testing
AUTO_REMEDIATION_SEVERITY_LIMIT=medium  # Don't auto-remediate critical incidents
REQUIRE_HUMAN_APPROVAL_FOR_ACTIONS=true
ENABLE_PII_REDACTION=true

# ============================================================================
# Observability for the Agent
# ============================================================================

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json or text
ENABLE_DETAILED_LOGGING=true
LOG_PII_REDACTED=true

# Metrics
ENABLE_METRICS=true
METRICS_NAMESPACE=AI-Incident-Agent
METRICS_DIMENSIONS=Environment,Version

# Prometheus (Optional)
PROMETHEUS_PORT=9090
PROMETHEUS_ENABLED=false

# ============================================================================
# Performance & Optimization
# ============================================================================

# Caching
ENABLE_REDIS_CACHE=false
REDIS_ENDPOINT=  # Redis cluster endpoint
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_TTL=3600  # seconds

# Rate Limiting
LLM_RATE_LIMIT_RPM=100  # Requests per minute
LLM_RATE_LIMIT_TPM=100000  # Tokens per minute

# Retry Configuration
MAX_RETRIES=3
RETRY_BACKOFF_MULTIPLIER=2
RETRY_MAX_WAIT_SECONDS=10

# ============================================================================
# Feature Flags
# ============================================================================

# Experimental Features
ENABLE_INCIDENT_CORRELATION=false
ENABLE_PROACTIVE_ALERTS=false
ENABLE_CAPACITY_PLANNING_SUGGESTIONS=false

# Learning & Feedback
ENABLE_FEEDBACK_COLLECTION=true
FEEDBACK_REMINDER_SECONDS=3600  # 1 hour after incident
AUTO_UPDATE_RUNBOOKS=false

# ============================================================================
# Development & Testing
# ============================================================================

# Environment
ENVIRONMENT=development  # development, staging, production
DEBUG=false

# Testing
ENABLE_TEST_ALERTS=true  # Allow manual test alerts
TEST_ALERT_PREFIX=TEST-

# Local Development
USE_LOCALSTACK=false  # Use LocalStack for local AWS services
LOCALSTACK_ENDPOINT=http://localhost:4566

# ============================================================================
# Security
# ============================================================================

# Secrets Manager (Optional - for rotating secrets)
USE_SECRETS_MANAGER=false
SLACK_TOKEN_SECRET_NAME=ai-incident-agent/slack-token
PAGERDUTY_KEY_SECRET_NAME=ai-incident-agent/pagerduty-key

# Encryption
ENABLE_S3_ENCRYPTION=true
S3_KMS_KEY_ID=  # Leave empty for default AWS-managed key
ENABLE_DYNAMODB_ENCRYPTION=true

# ============================================================================
# Cost Controls
# ============================================================================

# Budget Alerts
MAX_DAILY_LLM_CALLS=5000
MAX_DAILY_COST_DOLLARS=100
ALERT_ON_COST_THRESHOLD=0.8  # Alert at 80% of budget

# ============================================================================
# Contact & Escalation
# ============================================================================

# Ops Team Contact
OPS_TEAM_SLACK_CHANNEL=#ops-team
OPS_TEAM_EMAIL=ops-team@company.com
OPS_TEAM_PAGERDUTY_ESCALATION=escalation-policy-id

# Agent Owner
AGENT_OWNER_EMAIL=genai-enablement@company.com
AGENT_SUPPORT_CHANNEL=#ai-incident-agent-support
